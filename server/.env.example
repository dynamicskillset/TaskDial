# JWT signing secret — generate with:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# Access token lifetime in seconds (default: 3600 = 1 hour)
JWT_ACCESS_EXPIRES=3600

# Refresh token lifetime in seconds (default: 2592000 = 30 days)
JWT_REFRESH_EXPIRES=2592000

# Allowed frontend origin for CORS
APP_ORIGIN=http://localhost:5173

# Port the server listens on (default: 3001)
PORT=3001

# Set to 'production' on the server
NODE_ENV=development

# Owner account — used only on first run to seed the admin account.
# If OWNER_PASSWORD is not set, a random password is printed once to stdout.
OWNER_EMAIL=
OWNER_PASSWORD=
